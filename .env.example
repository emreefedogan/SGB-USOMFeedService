# CrowdStrike Falcon API Kimlik Bilgileri
# Bu bilgileri doldurarak ".env" adıyla kaydedin.

# CrowdStrike Falcon API Client ID (Indicators - Read/Write yetkisi gerekli)
FALCON_CLIENT_ID="YOUR_CLIENT_ID_HERE"

# CrowdStrike Falcon API Client Secret
FALCON_CLIENT_SECRET="YOUR_CLIENT_SECRET_HERE"

# Falcon IOC Action: "prevent" (engelle) veya "detect" (sadece alarm)
FALCON_IOC_ACTION="prevent"
